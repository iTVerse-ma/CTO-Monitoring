{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Connecteo — Containers & Host",
  "uid": "connecteo-overview",
  "tags": ["connecteo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat", "title": "Host CPU used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" } ]
    },
    {
      "type": "stat", "title": "Host RAM used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)" } ]
    },
    {
      "type": "stat", "title": "Root FS used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} * 100)" } ]
    },
    {
      "type": "stat", "title": "Running containers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "count(count by(name)(container_last_seen{name!=\"\"}))" } ]
    },
    {
      "type": "timeseries", "title": "Container CPU (cores)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by(name)(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))", "legendFormat": "{{name}}" } ]
    },
    {
      "type": "timeseries", "title": "Container memory (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by(name)(container_memory_usage_bytes{name!=\"\"})", "legendFormat": "{{name}}" } ]
    }
  ]
}
